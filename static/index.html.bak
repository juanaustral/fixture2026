<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Akira OS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Newsreader:opsz,wght@12..72,400;12..72,500;12..72,600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050508; --bg2:#0a0b10; --surface:rgba(255,255,255,0.03);
  --surface2:rgba(255,255,255,0.05); --surface3:rgba(255,255,255,0.08);
  --border:rgba(255,255,255,0.06); --border2:rgba(255,255,255,0.10);
  --text:#f0f0f5; --text2:rgba(255,255,255,0.55); --text3:rgba(255,255,255,0.28);
  --accent:#6C5CE7; --accent-dim:rgba(108,92,231,0.12); --accent-glow:rgba(108,92,231,0.3);
  --green:#00D68F; --green-bg:rgba(0,214,143,0.08);
  --warning:#FFAA00; --warning-bg:rgba(255,170,0,0.08);
  --danger:#FF4757; --danger-bg:rgba(255,71,87,0.08);
  --cyan:#00D4FF; --cyan-dim:rgba(0,212,255,0.10);
  --radius:16px; --radius-sm:12px; --radius-xs:8px;
  --font:'Geist',-apple-system,sans-serif; --mono:'Geist Mono','SF Mono',monospace;
  --gap:14px; --t:180ms cubic-bezier(0.16,1,0.3,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;font-family:var(--font)}
body{background:radial-gradient(ellipse at 50% 0%,rgba(108,92,231,0.06)0%,transparent 60%),var(--bg);color:var(--text);font-size:13px;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased}

/* HEADER */
#header{height:54px;display:flex;align-items:center;gap:4px;flex-shrink:0;padding:0 20px;background:rgba(10,11,16,0.85);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);z-index:50}
.header-brand{font-weight:700;font-size:15px;letter-spacing:-0.3px;display:flex;align-items:center;gap:7px;padding-right:24px;color:var(--text)}
.header-brand span{color:var(--accent)}
.tab{padding:7px 15px;border-radius:9px;font-size:12.5px;color:var(--text2);cursor:pointer;transition:var(--t);border:none;background:transparent;font-family:var(--font);font-weight:500;letter-spacing:-0.1px}
.tab:hover{color:var(--text);background:var(--surface2)}
.tab.active{background:var(--accent-dim);color:var(--accent);font-weight:600}
.header-spacer{flex:1}
.status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;box-shadow:0 0 8px currentColor}
.btn-icon{width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:9px;border:1px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;font-size:15px;transition:var(--t)}
.btn-icon:hover{background:var(--surface3);color:var(--text);border-color:var(--border2)}

/* MAIN */
#main{flex:1;overflow:hidden;display:flex;flex-direction:column}
.section{flex:1;overflow-y:auto;display:none;padding:18px}
.section.active{display:flex;flex-direction:column}
.section::-webkit-scrollbar{width:4px}
.section::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* ── DASHBOARD ── */
.kpi-hero{background:linear-gradient(135deg,var(--surface)0%,var(--surface2)100%);border:1px solid var(--border);border-radius:var(--radius);padding:26px 28px;margin-bottom:var(--gap);display:flex;gap:20px;align-items:center}
.kpi-main{flex:1}
.kpi-score{font-size:68px;font-weight:700;letter-spacing:-2.5px;line-height:1}
.kpi-label{font-size:13px;color:var(--text2);margin-top:3px;font-weight:500}
.kpi-bar{width:100%;height:4px;background:rgba(255,255,255,0.04);border-radius:2px;margin-top:12px;overflow:hidden}
.kpi-bar-fill{height:100%;border-radius:2px;transition:width 0.7s var(--t)}
.kpi-details{display:flex;flex-direction:column;gap:7px;min-width:240px}
.kpi-detail{font-size:12.5px;color:var(--text2);display:flex;align-items:center;gap:8px}
.metrics-row{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap);margin-bottom:var(--gap)}
.metric-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;transition:var(--t);cursor:default}
.metric-card:hover{border-color:var(--border2);background:var(--surface2)}
.metric-card.alert{border-color:rgba(255,71,87,0.15);background:rgba(255,71,87,0.03)}
.metric-card.warn{border-color:rgba(255,170,0,0.15);background:rgba(255,170,0,0.03)}
.metric-header{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.metric-title{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.05em;font-weight:600}
.metric-value{font-size:28px;font-weight:700;letter-spacing:-0.8px}
.metric-sub{font-size:11px;color:var(--text3);margin-top:1px;font-family:var(--mono)}
.metric-trend{font-size:10.5px;margin-top:6px;font-weight:500}
.metric-trend.ok{color:var(--green)}.metric-trend.warn{color:var(--warning)}.metric-trend.err{color:var(--danger)}
.panels-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--gap);margin-bottom:var(--gap)}
.panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.panel-header{display:flex;align-items:center;gap:8px;padding:14px 18px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;transition:var(--t)}
.panel-header:hover{background:var(--surface2)}
.panel.collapsed .caret{transform:rotate(-90deg)}
.caret{font-size:9px;transition:transform 0.15s;color:var(--text3)}
.panel-title{flex:1;font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.04em}
.panel-badge{font-size:10.5px;padding:2px 10px;border-radius:10px;font-weight:600}
.panel-body{padding:12px 18px;max-height:280px;overflow-y:auto}
.panel.collapsed .panel-body{display:none}
.list-item{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border);font-size:12.5px}
.list-item:last-child{border-bottom:none}
.list-status{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.list-status.up{background:var(--green);box-shadow:0 0 6px rgba(0,214,143,0.4)}
.list-status.down{background:var(--danger)}
.list-status.warn{background:var(--warning)}
.list-text{flex:1;color:var(--text2)}.list-text strong{color:var(--text);font-weight:600}
.list-meta{font-size:10.5px;color:var(--text3);font-family:var(--mono)}
.activity{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px}
.activity-title{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:8px}
.activity-line{font-family:var(--mono);font-size:9.5px;color:var(--text3);padding:2px 0;display:flex;gap:10px}
.activity-line .ok{color:var(--green)}.activity-line .err{color:var(--danger)}.activity-line .warn{color:var(--warning)}

/* ── CHAT ── */
.chat-messages{flex:1;overflow-y:auto;padding:0 0 var(--gap)0;display:flex;flex-direction:column;gap:10px}
.chat-msg{max-width:75%;padding:11px 15px;border-radius:var(--radius-sm);font-size:13px;line-height:1.5}
.chat-msg.user{align-self:flex-end;background:var(--accent);color:#fff;border-bottom-right-radius:4px}
.chat-msg.assistant{align-self:flex-start;background:var(--surface);border:1px solid var(--border);border-bottom-left-radius:4px}
.chat-msg.assistant pre{background:var(--bg);padding:10px 14px;border-radius:8px;overflow-x:auto;font-family:var(--mono);font-size:10.5px;margin:5px 0;border:1px solid var(--border)}
.chat-input-row{display:flex;gap:10px;padding:var(--gap)0 0 0;border-top:1px solid var(--border);flex-shrink:0}
.chat-input{flex:1;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--font);font-size:13px;outline:none;resize:none;min-height:42px;max-height:120px}
.chat-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim)}
.chat-send{padding:10px 20px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-sm);cursor:pointer;font-family:var(--font);font-size:13px;font-weight:600;transition:var(--t);white-space:nowrap}
.chat-send:hover{filter:brightness(1.1)}.chat-send:disabled{opacity:0.4;cursor:not-allowed}

/* ── AGENDA ── */
.agenda-toolbar{display:flex;gap:8px;margin-bottom:var(--gap);flex-shrink:0;flex-wrap:wrap}
.agenda-btn{padding:8px 16px;border-radius:9px;border:1px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;font-size:12px;font-family:var(--font);font-weight:500;transition:var(--t)}
.agenda-btn:hover{border-color:var(--border2);color:var(--text)}
.agenda-btn.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.agenda-layout{display:grid;grid-template-columns:1fr 1fr;gap:var(--gap);flex:1;overflow:hidden}
.agenda-col{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;overflow:hidden}
.agenda-col-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.04em;flex-shrink:0}
.agenda-col-body{flex:1;overflow-y:auto;padding:10px}
.agenda-col-footer{padding:10px 14px;border-top:1px solid var(--border);display:flex;gap:8px;flex-shrink:0}
.agenda-input{flex:1;padding:9px 12px;border:1px solid var(--border);border-radius:9px;font-family:var(--font);font-size:12px;outline:none;background:var(--bg);color:var(--text)}
.agenda-input:focus{border-color:var(--accent)}
.event-card,.task-card{padding:12px 14px;border-radius:10px;margin-bottom:5px;border:1px solid var(--border);transition:var(--t);cursor:default}
.event-card:hover,.task-card:hover{border-color:var(--border2);background:var(--surface2)}
.task-card.done{opacity:0.35}.task-card.done .task-title{text-decoration:line-through}
.event-date-badge{font-size:10.5px;font-weight:600;padding:3px 10px;border-radius:8px;display:inline-block;margin-bottom:5px}
.event-date-badge.today{background:var(--accent-dim);color:var(--accent)}
.event-date-badge.soon{background:var(--cyan-dim);color:var(--cyan)}
.event-date-badge.later{background:var(--surface3);color:var(--text2)}
.event-title,.task-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:1px}
.event-time-loc{font-size:11px;color:var(--text2);font-family:var(--mono)}
.task-due{font-size:10.5px;margin-top:4px;font-family:var(--mono)}
.task-due.normal{color:var(--text3)}.task-due.overdue{color:var(--danger);font-weight:600}
.task-actions{display:flex;gap:6px;margin-top:8px}
.task-btn{padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:10.5px;font-family:var(--font);transition:var(--t);color:var(--text2)}
.task-btn:hover{color:var(--text);border-color:var(--border2)}
.task-btn.done-btn{color:var(--green);border-color:rgba(0,214,143,0.2)}.task-btn.done-btn:hover{background:var(--green-bg)}
.calendar-mini{padding:10px}.calendar-mini .cm-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.calendar-mini .cm-title{font-size:14px;font-weight:600}.cm-nav{display:flex;gap:4px}
.cm-nav button{width:30px;height:30px;border:1px solid var(--border);border-radius:8px;background:var(--surface);cursor:pointer;font-size:15px;color:var(--text2);display:flex;align-items:center;justify-content:center;transition:var(--t)}
.cm-nav button:hover{background:var(--surface2);color:var(--text)}
.cm-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;text-align:center}
.cm-day-hdr{font-size:9px;color:var(--text3);padding:3px 0;text-transform:uppercase;letter-spacing:0.04em;font-weight:600}
.cm-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:7px;font-size:11px;cursor:pointer;color:var(--text2);position:relative;transition:var(--t)}
.cm-day:hover{background:var(--surface3)}
.cm-day.today{background:var(--accent-dim);color:var(--accent);font-weight:700}
.cm-day.selected{background:var(--accent);color:#fff;font-weight:700}
.cm-day.other{color:var(--text3)}.cm-day.has-event::after{content:'';position:absolute;bottom:3px;width:3px;height:3px;border-radius:50%;background:var(--accent)}
.selected-day-header{font-size:14px;font-weight:600;margin-bottom:10px;padding:0 4px}
.empty-state{text-align:center;padding:28px 16px;color:var(--text3);font-size:12.5px}

/* ── NOTAS ── */
#notasSection.active{flex-direction:row}
.notas-sidebar{width:280px;flex-shrink:0;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;overflow:hidden;margin-right:var(--gap)}
.notas-sb-search{padding:10px 12px;border-bottom:1px solid var(--border)}
.notas-sb-search input{width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:var(--font);outline:none;background:var(--bg);color:var(--text)}
.notas-sb-search input:focus{border-color:var(--accent)}
.notas-sb-tree{flex:1;overflow-y:auto;padding:6px}
.notas-sb-item{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;cursor:pointer;font-size:12px;color:var(--text2);transition:var(--t);user-select:none}
.notas-sb-item:hover{background:var(--surface2);color:var(--text)}
.notas-sb-item.active{background:var(--accent-dim);color:var(--accent);font-weight:600}
.notas-sb-item .sb-date{font-size:10px;color:var(--text3);margin-left:auto;font-family:var(--mono);flex-shrink:0}
.notas-sb-children{margin-left:14px}
.notas-sb-children.hidden{display:none}
.notas-sb-footer{padding:8px 12px;border-top:1px solid var(--border);flex-shrink:0}
.notas-sb-footer button{width:100%;padding:9px;border-radius:9px;border:none;background:var(--accent);color:#fff;cursor:pointer;font-size:12px;font-family:var(--font);font-weight:600;transition:var(--t)}
.notas-sb-footer button:hover{filter:brightness(1.1)}
.notas-main-area{flex:1;display:flex;flex-direction:column;overflow:hidden}
.notas-welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--text3);gap:6px}
.notas-welcome .nw-icon{font-size:44px;margin-bottom:6px;opacity:0.3}
.notas-welcome .nw-title{font-size:15px;font-weight:600;color:var(--text2)}
.notas-welcome .nw-hint{font-size:12.5px}
.notas-editor-wrap{flex:1;display:none;flex-direction:column;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.notas-editor-wrap.open{display:flex}
.notas-editor-hdr{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.notas-editor-hdr input{font-size:15px;font-weight:600;border:none;outline:none;font-family:var(--font);color:var(--text);background:transparent;flex:1}
.notas-editor-hdr input::placeholder{color:var(--text3)}
.notas-editor-actions{display:flex;gap:6px;flex-shrink:0}
.nbtn{padding:6px 12px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;font-size:11px;font-family:var(--font);transition:var(--t);white-space:nowrap}
.nbtn:hover{border-color:var(--border2);color:var(--text)}
.nbtn.primary{background:var(--accent);color:#fff;border-color:var(--accent)}.nbtn.primary:hover{filter:brightness(1.1)}
.nbtn.danger{color:var(--danger);border-color:rgba(255,71,87,0.2)}.nbtn.danger:hover{background:var(--danger-bg)}
.notas-toolbar{display:flex;gap:2px;padding:6px 14px;border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap}
.tbtn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:6px;border:1px solid transparent;background:transparent;cursor:pointer;font-family:var(--mono);font-size:12px;color:var(--text2);transition:var(--t)}
.tbtn:hover{background:var(--surface2);color:var(--text);border-color:var(--border)}
.tsep{width:1px;background:var(--border);margin:0 3px}
.notas-body{flex:1;overflow-y:auto}
.notas-body textarea{width:100%;height:100%;min-height:300px;border:none;outline:none;resize:none;font-family:var(--mono);font-size:12.5px;line-height:1.7;color:var(--text);background:transparent;padding:18px}
.notas-body .preview{padding:18px;font-size:13px;line-height:1.7;display:none}
.notas-body .preview.show{display:block}
.notas-body .preview h1{font-size:22px;font-weight:700;margin-bottom:10px;color:var(--text)}
.notas-body .preview h2{font-size:17px;font-weight:600;margin:18px 0 6px;color:var(--text)}
.notas-body .preview h3{font-size:14px;font-weight:600;margin:14px 0 4px}
.notas-body .preview p{margin-bottom:8px}
.notas-body .preview ul,.notas-body .preview ol{margin:6px 0;padding-left:20px}
.notas-body .preview li{margin-bottom:3px}
.notas-body .preview code{background:var(--bg);padding:2px 6px;border-radius:4px;font-family:var(--mono);font-size:11px}
.notas-body .preview pre{background:var(--bg);padding:14px;border-radius:8px;overflow-x:auto;font-family:var(--mono);font-size:11px;margin:10px 0;border:1px solid var(--border)}
.notas-body .preview blockquote{border-left:3px solid var(--accent);padding:6px 14px;margin:10px 0;color:var(--text2);background:var(--surface)}
.notas-meta{display:flex;gap:16px;font-size:10.5px;color:var(--text3);padding:8px 18px;font-family:var(--mono);flex-shrink:0;border-top:1px solid var(--border)}

/* TOAST */
#toasts{position:fixed;bottom:20px;right:20px;z-index:999;display:flex;flex-direction:column;gap:8px}
.toast{padding:10px 18px;border-radius:9px;font-size:12px;background:var(--surface2);border:1px solid var(--border2);backdrop-filter:blur(12px);animation:toastIn 0.2s;max-width:340px}
@keyframes toastIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:900px){.metrics-row{grid-template-columns:1fr 1fr}.agenda-layout,.panels-row{grid-template-columns:1fr}}
@media(max-width:640px){.metrics-row{grid-template-columns:1fr}.kpi-hero{flex-direction:column}.kpi-score{font-size:44px}#notasSection.active{flex-direction:column}.notas-sidebar{width:100%;margin-right:0;margin-bottom:var(--gap);max-height:180px}}
</style>
</head>
<body>

<header id="header">
  <div class="header-brand">Akira <span>OS</span></div>
  <button class="tab active" data-tab="dashboard" onclick="switchTab('dashboard')">Dashboard</button>
  <button class="tab" data-tab="chat" onclick="switchTab('chat')">Chat</button>
  <button class="tab" data-tab="notas" onclick="switchTab('notas')">Notas</button>
  <button class="tab" data-tab="agenda" onclick="switchTab('agenda')">Agenda</button>
  <div class="header-spacer"></div>
  <div class="status-dot" id="hdrDot" title="Estado del sistema"></div>
  <button class="btn-icon" onclick="refreshAll()" title="Actualizar">&#x21bb;</button>
</header>

<main id="main">

  <!-- ═══ DASHBOARD ═══ -->
  <section class="section active" id="section-dashboard">
    <div class="kpi-hero" id="kpiHero"><div class="kpi-main"><div class="kpi-score" id="kpiScore">--</div><div class="kpi-label" id="kpiLabel">Analizando sistema...</div><div class="kpi-bar"><div class="kpi-bar-fill" id="kpiBar" style="width:0%"></div></div></div><div class="kpi-details" id="kpiDetails"></div></div>
    <div class="metrics-row" id="metricsRow"></div>
    <div class="panels-row">
      <div class="panel" id="panelAgenda"><div class="panel-header" onclick="togglePanel('panelAgenda')"><span class="caret">&#x25bc;</span><span class="panel-title">Agenda Hoy</span><span class="panel-badge" style="background:var(--accent-dim);color:var(--accent)" id="panelBadgeAgenda">--</span></div><div class="panel-body" id="panelBodyAgenda"></div></div>
      <div class="panel" id="panelSites"><div class="panel-header" onclick="togglePanel('panelSites')"><span class="caret">&#x25bc;</span><span class="panel-title">Sitios</span><span class="panel-badge" style="background:var(--green-bg);color:var(--green)" id="panelBadgeSites">--</span></div><div class="panel-body" id="panelBodySites"></div></div>
    </div>
    <div class="activity"><div class="activity-title">Actividad reciente</div><div id="activityLines"></div></div>
  </section>

  <!-- ═══ CHAT ═══ -->
  <section class="section" id="section-chat">
    <div class="chat-messages" id="chatMessages"><div class="chat-msg assistant">Hola. Soy Akira. Preguntame lo que necesites.</div></div>
    <div class="chat-input-row"><textarea class="chat-input" id="chatInput" placeholder="Escribi tu mensaje..." rows="1" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChat()}"></textarea><button class="chat-send" id="chatSendBtn" onclick="sendChat()">Enviar</button></div>
  </section>

  <!-- ═══ AGENDA ═══ -->
  <section class="section" id="section-agenda">
    <div class="agenda-toolbar">
      <button class="agenda-btn active" onclick="setAgendaView('upcoming',this)">Proximos</button>
      <button class="agenda-btn" onclick="setAgendaView('tasks',this)">Tareas</button>
      <button class="agenda-btn" onclick="setAgendaView('calendar',this)">Calendario</button>
      <span style="flex:1"></span>
      <span style="font-size:11px;color:var(--text3);display:flex;align-items:center" id="agendaLastSync"></span>
    </div>
    <div class="agenda-layout" id="agendaLayout"></div>
  </section>

  <!-- ═══ NOTAS ═══ -->
  <section class="section" id="section-notas">
    <div class="notas-sidebar">
      <div class="notas-sb-search"><input type="text" placeholder="Buscar notas..." oninput="doFilterNotas(this.value)" id="notasSearch"></div>
      <div class="notas-sb-tree" id="notasTreeEl"></div>
      <div class="notas-sb-footer"><button onclick="doNewNota()">+ Nueva nota</button></div>
    </div>
    <div class="notas-main-area">
      <div class="notas-welcome" id="notasWelcome"><div class="nw-icon">&#x1f4c4;</div><div class="nw-title">Tus notas de SilverBullet</div><div class="nw-hint">Selecciona una nota para editarla, o crea una nueva</div></div>
      <div class="notas-editor-wrap" id="notasEditorWrap">
        <div class="notas-editor-hdr"><input id="notasTitleInput" placeholder="Titulo de la nota..." oninput="notasDirty=true"><div class="notas-editor-actions"><button onclick="doTogglePreview()" class="nbtn" id="previewBtn">Vista previa</button><button onclick="doSaveNota()" class="nbtn primary">Guardar</button><button onclick="doDeleteNota()" class="nbtn danger">Eliminar</button></div></div>
        <div class="notas-toolbar">
          <button class="tbtn" onclick="doInsertMD('**','**')" title="Negrita"><b>B</b></button>
          <button class="tbtn" onclick="doInsertMD('*','*')" title="Cursiva"><i>I</i></button>
          <button class="tbtn" onclick="doInsertMD('## ','')" title="Titulo">H</button>
          <span class="tsep"></span>
          <button class="tbtn" onclick="doInsertMD('- ','')" title="Lista">-</button>
          <button class="tbtn" onclick="doInsertMD('1. ','')" title="Lista num">1.</button>
          <button class="tbtn" onclick="doInsertMD('[','](url)')" title="Link">A</button>
          <span class="tsep"></span>
          <button class="tbtn" onclick="doInsertMD('\n```\n','\n```\n')" title="Codigo">&lt;/&gt;</button>
          <button class="tbtn" onclick="doInsertMD('> ','')" title="Cita">&ldquo;</button>
          <button class="tbtn" onclick="doInsertMD('---\n','')" title="Linea">--</button>
        </div>
        <div class="notas-meta" id="notasMeta"></div>
        <div class="notas-body"><textarea id="notasTextarea" placeholder="Escribi tu nota en Markdown..." oninput="notasDirty=true;if(notasPreviewMode)doRenderPreview()"></textarea><div class="preview" id="notasPreview"></div></div>
      </div>
    </div>
  </section>
</main>
<div id="toasts"></div>

<script>
const BASE=location.origin;
let state={vps:{},docker:{},sites:{},notas:{},github:{},tasks:{},calendar:{},deepseek:{}};
let activity=[],activeTab='dashboard',agendaView='upcoming';
let currentNotaPath=null,notasTreeData=[],notasDirty=false,notasPreviewMode=false;
let agendaEvents=[],agendaTasks=[],agendaCalendarDate=new Date();
let calYear,calMonth;
let chatHistory=[{role:'assistant',content:'Hola. Soy Akira. Preguntame lo que necesites.'}];

function $(id){return document.getElementById(id)}
function switchTab(tab){activeTab=tab;document.querySelectorAll('.tab').forEach(function(t){t.classList.toggle('active',t.dataset.tab===tab)});document.querySelectorAll('.section').forEach(function(s){s.classList.remove('active')});$('section-'+tab).classList.add('active');if(tab==='dashboard')render();if(tab==='chat')$('chatInput').focus();if(tab==='notas')doLoadNotas();if(tab==='agenda')doLoadAgenda()}

async function fetchAll(){try{var r=await fetch(BASE+'/api/all');state=await r.json();render();logActivity('ok','Actualizado')}catch(e){logActivity('err','Error: '+e.message)}}
async function refreshAll(){await fetchAll();toast('Actualizado')}
function togglePanel(id){$(id).classList.toggle('collapsed')}

/* ── DASHBOARD ── */
function calcHealth(){
  var s=100,issues=[];
  var v=state.vps||{},dk=state.docker||{},ds=state.deepseek||{};
  var sites=(state.sites&&state.sites.sites)?state.sites.sites:[];
  var cpu=parseFloat(v.cpu)||0;
  if(cpu>85){s-=25;issues.push({level:'err',text:'CPU: '+cpu.toFixed(0)+'%'})}else if(cpu>60){s-=10;issues.push({level:'warn',text:'CPU: '+cpu.toFixed(0)+'%'})}
  var mu=parseInt((v.mem&&v.mem.used)||0),mt=parseInt((v.mem&&v.mem.total)||1),mp=(mu/mt*100);
  if(mp>90){s-=30;issues.push({level:'err',text:'RAM: '+mp.toFixed(0)+'%'})}else if(mp>70){s-=12;issues.push({level:'warn',text:'RAM: '+mp.toFixed(0)+'%'})}
  var dp=parseFloat((v.disk&&v.disk.pct)||0);
  if(dp>90){s-=20;issues.push({level:'err',text:'Disco: '+dp+'%'})}else if(dp>75){s-=8;issues.push({level:'warn',text:'Disco: '+dp+'%'})}
  var cs=dk.containers||[],stopped=cs.filter(function(c){return c.state!=='running'});
  if(stopped.length>0){s-=12;issues.push({level:'warn',text:stopped.length+' contenedor(es) detenido(s)'})}
  var down=sites.filter(function(s){return s.status!=='up'});
  if(down.length>0){s-=10*down.length;issues.push({level:'err',text:down.length+' sitio(s) inaccesible(s)'})}
  if(!ds.available){s-=5;issues.push({level:'warn',text:'DeepSeek sin conexion'})}else if(parseFloat(ds.balance)<2){s-=15;issues.push({level:'err',text:'DeepSeek: saldo critico'})}
  return{score:Math.max(0,s),issues:issues};
}
function renderKPI(h){
  var s=h.score,color,label;
  if(s>=90){color='var(--green)';label='Sistema saludable'}else if(s>=70){color='var(--warning)';label='Requiere atencion'}else{color='var(--danger)';label='Estado critico'}
  $('kpiScore').style.color=color;$('kpiScore').textContent=s;$('kpiLabel').textContent=label;
  $('kpiBar').style.width=s+'%';$('kpiBar').style.background=color;
  $('kpiDetails').innerHTML=h.issues.length===0?'<span style="color:var(--green);font-size:12.5px">Todos los sistemas operativos</span>':h.issues.map(function(i){return'<div class="kpi-detail"><span class="list-status '+(i.level==='err'?'down':'warn')+'"></span>'+escHtml(i.text)+'</div>'}).join('');
  $('hdrDot').style.background=s>=90?'var(--green)':s>=70?'var(--warning)':'var(--danger)';
}
function renderMetrics(){
  var v=state.vps||{},dk=state.docker||{},ds=state.deepseek||{};
  var cal=(state.calendar&&state.calendar.events)?state.calendar.events:[];
  var cpu=parseFloat(v.cpu)||0,mu=parseInt((v.mem&&v.mem.used)||0),mt=parseInt((v.mem&&v.mem.total)||1);
  var mp=Math.round(mu/mt*100),dp=parseFloat((v.disk&&v.disk.pct)||0);
  var cs=dk.containers||[],running=cs.filter(function(c){return c.state==='running'}).length;
  var bal=ds.available?parseFloat(ds.balance):null;
  var now=new Date(),DAY_MS=86400000;
  var upcoming=cal.filter(function(e){var d=e.start?new Date(e.start):null;return d&&d>now&&d<new Date(now.getTime()+DAY_MS)});
  var cards=[{title:'CPU',val:cpu.toFixed(0)+'%',sub:v.load||'',trend:cpu>80?'Alto':cpu>60?'Moderado':'Normal',trendCls:cpu>80?'err':cpu>60?'warn':'ok',cls:cpu>80?'alert':cpu>60?'warn':''},{title:'RAM',val:mp+'%',sub:(mu/1024).toFixed(1)+' / '+(mt/1024).toFixed(1)+' GB',trend:mp>85?'Critica':mp>70?'Alta':'Normal',trendCls:mp>85?'err':mp>70?'warn':'ok',cls:mp>85?'alert':mp>70?'warn':''},{title:'Disco',val:dp+'%',sub:(v.disk&&v.disk.used||'?')+' / '+(v.disk&&v.disk.total||'?'),trend:dp>90?'Critico':dp>75?'Alto':'Normal',trendCls:dp>90?'err':dp>75?'warn':'ok',cls:dp>90?'alert':dp>75?'warn':''},{title:'Servicios',val:running+' / '+cs.length,sub:'Contenedores',trend:running===cs.length?'Todos operativos':(cs.length-running)+' detenidos',trendCls:running===cs.length?'ok':'warn',cls:running<cs.length?'warn':''},{title:'DeepSeek',val:bal!==null?'$'+bal.toFixed(2):'--',sub:'USD disponibles',trend:bal!==null?(bal<2?'Critico':bal<5?'Bajo':'OK'):'Offline',trendCls:bal!==null&&bal<2?'err':bal!==null&&bal<5?'warn':'ok',cls:bal!==null&&bal<2?'alert':bal!==null&&bal<5?'warn':''},{title:'Eventos Hoy',val:upcoming.length+' / '+cal.length,sub:'Prox. 24h / Total',trend:upcoming.length>0?upcoming.length+' eventos hoy':'Sin eventos',trendCls:'ok',cls:''}];
  $('metricsRow').innerHTML=cards.map(function(c){return'<div class="metric-card '+c.cls+'"><div class="metric-header"><span class="metric-title">'+escHtml(c.title)+'</span></div><div class="metric-value">'+escHtml(c.val)+'</div><div class="metric-sub">'+escHtml(c.sub)+'</div><div class="metric-trend '+c.trendCls+'">'+escHtml(c.trend)+'</div></div>'}).join('');
}
function renderPanels(){
  var cal=(state.calendar&&state.calendar.events)?state.calendar.events:[];
  var tasks=(state.tasks&&state.tasks.tasks)?state.tasks.tasks:[];
  var sites=(state.sites&&state.sites.sites)?state.sites.sites:[];
  var now=new Date(),DAY_MS=86400000,today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
  var upcoming=cal.filter(function(e){var d=e.start?new Date(e.start):null;return d&&d>=today&&d<new Date(today.getTime()+DAY_MS)});
  $('panelBadgeAgenda').textContent=upcoming.length+' hoy';
  var h='';
  upcoming.slice(0,6).forEach(function(e){var d=e.start?new Date(e.start):null;h+='<div class="list-item"><span class="list-status up"></span><span class="list-text"><strong>'+escHtml(e.summary||'Sin titulo')+'</strong></span><span class="list-meta">'+(d?d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}):'')+'</span></div>'});
  if(upcoming.length===0)h+='<div class="empty-state">Sin eventos hoy</div>';
  if(tasks.length>0){h+='<div style="font-size:11px;font-weight:600;color:var(--text2);margin:14px 0 8px;text-transform:uppercase;letter-spacing:0.03em">Tareas ('+tasks.length+')</div>';tasks.slice(0,5).forEach(function(t){h+='<div class="list-item"><span class="list-status warn"></span><span class="list-text">'+escHtml(t.title||'Sin titulo')+'</span><span class="list-meta">'+(t.due||'')+'</span></div>'})}
  $('panelBodyAgenda').innerHTML=h;
  var upCount=sites.filter(function(s){return s.status==='up'}).length;
  $('panelBadgeSites').textContent=upCount+' / '+sites.length;
  $('panelBodySites').innerHTML=sites.map(function(s){return'<div class="list-item"><span class="list-status '+(s.status==='up'?'up':'down')+'"></span><span class="list-text"><strong>'+escHtml(s.name)+'</strong></span><span class="list-meta">'+escHtml(s.url)+'</span></div>'}).join('')||'<div class="empty-state">Sin sitios</div>';
}
function logActivity(l,m){var t=new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});activity.unshift({t:t,level:l,msg:m});if(activity.length>50)activity.pop();if(activeTab==='dashboard')renderActivity()}
function renderActivity(){$('activityLines').innerHTML=activity.slice(0,15).map(function(a){return'<div class="activity-line"><span class="ts">'+a.t+'</span><span class="'+a.level+'">['+a.level.toUpperCase()+']</span>'+escHtml(a.msg)+'</div>'}).join('')}
function render(){if(activeTab!=='dashboard')return;var h=calcHealth();renderKPI(h);renderMetrics();renderPanels();renderActivity()}

/* ── CHAT ── */
async function sendChat(){
  var input=$('chatInput'),msg=input.value.trim();if(!msg)return;input.value='';input.style.height='auto';
  chatHistory.push({role:'user',content:msg});renderChatMessages();$('chatSendBtn').disabled=true;
  try{var messages=chatHistory.filter(function(m){return m.role!=='system'}).slice(-20);var r=await fetch(BASE+'/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messages:messages})});var d=await r.json();chatHistory.push({role:'assistant',content:d.response||'Sin respuesta'});renderChatMessages()}catch(e){chatHistory.push({role:'assistant',content:'Error de conexion'});renderChatMessages()}
  $('chatSendBtn').disabled=false;$('chatInput').focus();
}
function renderChatMessages(){$('chatMessages').innerHTML=chatHistory.map(function(m){return'<div class="chat-msg '+m.role+'">'+escHtml(m.content).replace(/\n/g,'<br>')+'</div>'}).join('');$('chatMessages').scrollTop=$('chatMessages').scrollHeight}

/* ── AGENDA ── */
async function doLoadAgenda(){
  try{var _a=await Promise.all([fetch(BASE+'/api/calendar'),fetch(BASE+'/api/tasks')]);var c=await _a[0].json(),t=await _a[1].json();agendaEvents=c.events||[];agendaTasks=t.tasks||[];$('agendaLastSync').textContent='Actualizado '+new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'});renderAgendaView()}catch(e){$('agendaLayout').innerHTML='<div class="empty-state">Error al cargar datos de Google</div>'}}
function setAgendaView(v,btn){agendaView=v;document.querySelectorAll('.agenda-btn').forEach(function(b){b.classList.remove('active')});btn.classList.add('active');renderAgendaView()}
function getBadge(d){var now=new Date(),today=new Date(now.getFullYear(),now.getMonth(),now.getDate());var tomorrow=new Date(today);tomorrow.setDate(tomorrow.getDate()+1);var weekEnd=new Date(today);weekEnd.setDate(weekEnd.getDate()+7);if(d.toDateString()===today.toDateString())return{cls:'today',label:'Hoy'};if(d.toDateString()===tomorrow.toDateString())return{cls:'today',label:'Manana'};if(d<weekEnd)return{cls:'soon',label:d.toLocaleDateString('es-AR',{weekday:'long',day:'numeric'})};return{cls:'later',label:d.toLocaleDateString('es-AR',{month:'short',day:'numeric'})}}
function renderAgendaView(){if(agendaView==='upcoming')rvUpcoming();else if(agendaView==='tasks')rvTasks();else if(agendaView==='calendar')rvCalendar()}
function rvUpcoming(){
  var DAY_MS=86400000,now=new Date(),today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
  var upcoming=agendaEvents.filter(function(e){var d=e.start?new Date(e.start):null;return d&&d>=today}).sort(function(a,b){return new Date(a.start)-new Date(b.start)});
  var weekEvents=upcoming.filter(function(e){var d=new Date(e.start);return d<new Date(today.getTime()+7*DAY_MS)});
  var leftHtml='<div class="agenda-col"><div class="agenda-col-header">Proximos 7 dias ('+weekEvents.length+')</div><div class="agenda-col-body">';
  if(weekEvents.length===0)leftHtml+='<div class="empty-state">Sin eventos esta semana</div>';
  else weekEvents.forEach(function(e){var d=new Date(e.start),b=getBadge(d);leftHtml+='<div class="event-card"><div class="event-date-badge '+b.cls+'">'+b.label+'</div><div class="event-title">'+escHtml(e.summary||'Sin titulo')+'</div><div class="event-time-loc">'+d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})+(e.location?' &middot; '+escHtml(e.location):'')+'</div></div>'});
  leftHtml+='</div></div>';
  var activeTasks=agendaTasks.filter(function(t){return t.status!=='completed'});
  var rightHtml='<div class="agenda-col"><div class="agenda-col-header">Tareas pendientes ('+activeTasks.length+')</div><div class="agenda-col-body">';
  if(activeTasks.length===0)rightHtml+='<div class="empty-state">Sin tareas pendientes</div>';
  else activeTasks.forEach(function(t){var isOverdue=t.due&&new Date(t.due)<new Date();rightHtml+='<div class="task-card"><div class="task-title">'+escHtml(t.title)+'</div>';if(t.notes)rightHtml+='<div style="font-size:11px;color:var(--text3);margin-top:2px">'+escHtml(t.notes).substring(0,100)+'</div>';if(t.due)rightHtml+='<div class="task-due'+(isOverdue?' overdue':' normal')+'">'+(isOverdue?'Vencida: ':'Vence: ')+new Date(t.due).toLocaleDateString('es-AR')+'</div>';rightHtml+='<div class="task-actions"><button class="task-btn done-btn" onclick="doCompleteTask(\''+t.id+'\')">Completar</button></div></div>'});
  rightHtml+='</div><div class="agenda-col-footer"><input class="agenda-input" id="newTask1" placeholder="Nueva tarea..." onkeydown="if(event.key===\'Enter\')doCreateTask()"><button class="agenda-btn active" onclick="doCreateTask()" style="white-space:nowrap">+ Agregar</button></div></div>';
  $('agendaLayout').innerHTML=leftHtml+rightHtml;
}
function rvTasks(){
  var active=agendaTasks.filter(function(t){return t.status!=='completed'}),completed=agendaTasks.filter(function(t){return t.status==='completed'});
  var html='<div class="agenda-col"><div class="agenda-col-header">Activas ('+active.length+')</div><div class="agenda-col-body">';
  if(active.length===0)html+='<div class="empty-state">Sin tareas activas</div>';
  else active.forEach(function(t){var isOverdue=t.due&&new Date(t.due)<new Date();html+='<div class="task-card"><div class="task-title">'+escHtml(t.title)+'</div>';if(t.notes)html+='<div style="font-size:11px;color:var(--text3);margin-top:2px">'+escHtml(t.notes).substring(0,120)+'</div>';if(t.due)html+='<div class="task-due'+(isOverdue?' overdue':' normal')+'">'+(isOverdue?'Vencida: ':'Vence: ')+new Date(t.due).toLocaleDateString('es-AR')+'</div>';html+='<div class="task-actions"><button class="task-btn done-btn" onclick="doCompleteTask(\''+t.id+'\')">Completar</button></div></div>'});
  html+='</div><div class="agenda-col-footer"><input class="agenda-input" id="newTask2" placeholder="Nueva tarea..." onkeydown="if(event.key===\'Enter\')doCreateTask()"><button class="agenda-btn active" onclick="doCreateTask()" style="white-space:nowrap">+ Agregar</button></div></div>';
  html+='<div class="agenda-col"><div class="agenda-col-header">Completadas ('+completed.length+')</div><div class="agenda-col-body">';
  if(completed.length===0)html+='<div class="empty-state">Sin tareas completadas</div>';
  else completed.slice(0,30).forEach(function(t){html+='<div class="task-card done"><div class="task-title">'+escHtml(t.title)+'</div></div>'});
  html+='</div></div>';$('agendaLayout').innerHTML=html;
}
function rvCalendar(){
  var today=new Date();if(!calYear){calYear=today.getFullYear();calMonth=today.getMonth()}
  var firstDay=new Date(calYear,calMonth,1).getDay(),daysInMonth=new Date(calYear,calMonth+1,0).getDate(),prevMonthDays=new Date(calYear,calMonth,0).getDate();
  var eventMap={};agendaEvents.forEach(function(e){var d=e.start?new Date(e.start):null;if(d){var k=d.getFullYear()+'-'+d.getMonth()+'-'+d.getDate();eventMap[k]=(eventMap[k]||0)+1}});
  var calHtml='<div class="calendar-mini"><div class="cm-header"><span class="cm-title">'+new Date(calYear,calMonth).toLocaleDateString('es-AR',{month:'long',year:'numeric'})+'</span><div class="cm-nav"><button onclick="calMonth--;if(calMonth<0){calMonth=11;calYear--};rvCalendar()" title="Anterior">&#x2039;</button><button onclick="var t=new Date();calYear=t.getFullYear();calMonth=t.getMonth();rvCalendar()" title="Hoy">Hoy</button><button onclick="calMonth++;if(calMonth>11){calMonth=0;calYear++};rvCalendar()" title="Siguiente">&#x203a;</button></div></div><div class="cm-grid">';
  calHtml+=['Do','Lu','Ma','Mi','Ju','Vi','Sa'].map(function(h){return'<div class="cm-day-hdr">'+h+'</div>'}).join('');
  for(var i=firstDay-1;i>=0;i--){calHtml+='<div class="cm-day other">'+(prevMonthDays-i)+'</div>'}
  var sel=agendaCalendarDate||today;
  for(var d=1;d<=daysInMonth;d++){var dob=new Date(calYear,calMonth,d);var isToday=today.toDateString()===dob.toDateString();var isSel=sel.toDateString()===dob.toDateString();var hasEv=eventMap[calYear+'-'+calMonth+'-'+d];calHtml+='<div class="cm-day'+(isToday?' today':'')+(isSel?' selected':'')+(hasEv?' has-event':'')+'" onclick="agendaCalendarDate=new Date('+calYear+','+calMonth+','+d+');rvCalendar()">'+d+'</div>'}
  calHtml+='</div></div>';
  var selEvents=agendaEvents.filter(function(e){var d=e.start?new Date(e.start):null;return d&&d.toDateString()===sel.toDateString()}).sort(function(a,b){return new Date(a.start)-new Date(b.start)});
  var evHtml='<div class="agenda-col"><div class="agenda-col-header">'+sel.toLocaleDateString('es-AR',{weekday:'long',day:'numeric',month:'long'})+' ('+selEvents.length+')</div><div class="agenda-col-body">';
  if(selEvents.length===0)evHtml+='<div class="empty-state">Sin eventos este dia</div>';
  else selEvents.forEach(function(e){var d=new Date(e.start);evHtml+='<div class="event-card"><div class="event-title">'+escHtml(e.summary||'Sin titulo')+'</div><div class="event-time-loc">'+d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'})+(e.location?' &middot; '+escHtml(e.location):'')+'</div></div>'});
  evHtml+='</div></div>';$('agendaLayout').innerHTML='<div class="agenda-col">'+calHtml+'</div>'+evHtml;
}
async function doCompleteTask(id){try{await fetch(BASE+'/api/tasks/complete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id})});toast('Tarea completada');await doLoadAgenda()}catch(e){toast('Error al completar')}}
async function doCreateTask(){var inp=$('newTask1')||$('newTask2');var title=(inp?inp.value:'').trim();if(!title)return;try{await fetch(BASE+'/api/tasks/create',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({title:title})});if(inp)inp.value='';toast('Tarea creada');await doLoadAgenda()}catch(e){toast('Error al crear tarea')}}

/* ── NOTAS ── */
async function doLoadNotas(){try{var r=await fetch(BASE+'/api/notas/tree');var d=await r.json();notasTreeData=d.tree||[];doFilterNotas(($('notasSearch')||{}).value||'')}catch(e){$('notasTreeEl').innerHTML='<div class="empty-state">Error al cargar notas</div>'}}
function doFilterNotas(q){q=(q||'').toLowerCase();var el=$('notasTreeEl');el.innerHTML='';if(!notasTreeData.length){el.innerHTML='<div class="empty-state">Sin notas</div>';return}buildTreeDOM(notasTreeData,0,q,el)}
function buildTreeDOM(items,level,q,parent){
  items.forEach(function(item){
    var match=!q||item.name.toLowerCase().indexOf(q)>=0;
    var childMatch=false;
    if(item.children)childMatch=item.children.some(function(c){return c.name.toLowerCase().indexOf(q)>=0||(c.children&&c.children.some(function(gc){return gc.name.toLowerCase().indexOf(q)>=0}))});
    if(!match&&!childMatch&&q)return;
    var div=document.createElement('div');
    div.className='notas-sb-item'+(currentNotaPath===item.path?' active':'');
    div.style.paddingLeft=(12+level*16)+'px';
    div.innerHTML='<span style="opacity:0.35;font-size:11px">'+(item.type==='folder'?'&#x1f4c1;':'&#x1f4c4;')+'</span><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+escHtml(item.name)+'</span>';
    if(item.type==='file'&&item.modified){var d=new Date(item.modified);div.innerHTML+='<span class="sb-date">'+d.toLocaleDateString('es-AR',{month:'short',day:'numeric'})+'</span>'}
    div.onclick=function(e){e.stopPropagation();if(item.type==='folder'){var next=div.nextElementSibling;if(next&&next.classList.contains('notas-sb-children'))next.classList.toggle('hidden')}else{doOpenNota(item.path)}};
    parent.appendChild(div);
    if(item.type==='folder'&&item.children&&item.children.length>0){var ch=document.createElement('div');ch.className='notas-sb-children';parent.appendChild(ch);buildTreeDOM(item.children,level+1,q,ch)}
  });
}
async function doOpenNota(path){
  if(notasDirty&&!confirm('Tenes cambios sin guardar. Descartar?'))return;
  currentNotaPath=path;notasDirty=false;
  try{
    var r=await fetch(BASE+'/api/notas/read?path='+encodeURIComponent(path));
    if(!r.ok){toast('Error al leer la nota');return}
    var d=await r.json();
    $('notasWelcome').style.display='none';
    $('notasEditorWrap').classList.add('open');
    $('notasTitleInput').value=path.replace(/\.md$/,'').split('/').pop();
    $('notasTextarea').value=d.content||'';
    if(notasPreviewMode)doRenderPreview();
    doUpdateMeta(path,d.content||'');
    doLoadNotas();
  }catch(e){toast('Error al cargar la nota')}
}
function doNewNota(){
  if(notasDirty&&!confirm('Tenes cambios sin guardar. Descartar?'))return;
  var name=prompt('Nombre de la nota (sin .md):');if(!name)return;
  var path='ideas/'+name+'.md';currentNotaPath=path;notasDirty=true;
  $('notasWelcome').style.display='none';$('notasEditorWrap').classList.add('open');
  $('notasTitleInput').value=name;
  var content='---\ntitle: '+name+'\ndate: '+new Date().toISOString().split('T')[0]+'\ntags: []\n---\n\n# '+name+'\n';
  $('notasTextarea').value=content;
  if(notasPreviewMode)doRenderPreview();
  doUpdateMeta(path,content);
}
async function doSaveNota(){
  if(!currentNotaPath)return;
  var content=$('notasTextarea').value;
  try{await fetch(BASE+'/api/notas/write',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:currentNotaPath,content:content})});notasDirty=false;toast('Guardado');doUpdateMeta(currentNotaPath,content);doLoadNotas()}catch(e){toast('Error al guardar')}
}
async function doDeleteNota(){
  if(!currentNotaPath||!confirm('Eliminar '+currentNotaPath+'?'))return;
  try{await fetch(BASE+'/api/notas/delete',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:currentNotaPath})});toast('Eliminado');currentNotaPath=null;notasDirty=false;$('notasWelcome').style.display='flex';$('notasEditorWrap').classList.remove('open');$('notasTextarea').value='';doLoadNotas()}catch(e){toast('Error al eliminar')}
}
function doUpdateMeta(path,content){var lines=content.split('\n').length,words=content.trim()?content.trim().split(/\s+/).length:0,chars=content.length;$('notasMeta').innerHTML=escHtml(path)+' &middot; '+lines+' lineas &middot; '+words+' palabras &middot; '+chars+' chars'}
function doInsertMD(before,after){var ta=$('notasTextarea'),start=ta.selectionStart,end=ta.selectionEnd,text=ta.value,sel=text.substring(start,end);ta.value=text.substring(0,start)+before+sel+after+text.substring(end);ta.focus();ta.selectionStart=ta.selectionEnd=start+before.length+sel.length+after.length;notasDirty=true}
function doTogglePreview(){notasPreviewMode=!notasPreviewMode;$('previewBtn').textContent=notasPreviewMode?'Editar':'Vista previa';$('notasTextarea').style.display=notasPreviewMode?'none':'block';$('notasPreview').style.display=notasPreviewMode?'block':'none';if(notasPreviewMode)doRenderPreview()}
function doRenderPreview(){var md=$('notasTextarea').value;var html=md.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/^### (.+)$/gm,'<h3>$1</h3>').replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/`([^`]+)`/g,'<code>$1</code>').replace(/^- (.+)$/gm,'<li>$1</li>').replace(/^> (.+)$/gm,'<blockquote>$1</blockquote>').replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br>');html='<p>'+html+'</p>';$('notasPreview').innerHTML=html;$('notasPreview').classList.add('show')}

/* ── UTILS ── */
function escHtml(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function toast(msg){var el=document.createElement('div');el.className='toast';el.textContent=msg;$('toasts').appendChild(el);setTimeout(function(){el.remove()},3000)}
document.addEventListener('keydown',function(e){if((e.metaKey||e.ctrlKey)&&e.key==='s'){e.preventDefault();if(activeTab==='notas')doSaveNota()}});

/* ── INIT ── */
logActivity('ok','Akira OS iniciado');fetchAll();setInterval(fetchAll,30000);
</script>
</body>
</html>
